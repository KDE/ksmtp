#: job.cpp:60
#, kde-format
msgid "Service not available"
msgstr "השירות לא זמין"

#: job.cpp:62
#, kde-format
msgid "Mailbox unavailable. The server said: %1"
msgstr "תיבת הדוא״ל לא זמינה. השרת הגיב: %1"

#: job.cpp:64
#, kde-format
msgid "Insufficient storage space on server. The server said: %1"
msgstr "אין מספיק מקום פנוי בשרת. השרת הגיב: %1"

#: job.cpp:66
#, kde-format
msgid "Server error: %1"
msgstr "שגיאת שרת: %1"

#: job.cpp:75
#, kde-format
msgid "Connection to server lost."
msgstr "החיבור לשרת אבד."

#: loginjob.cpp:77
#, kde-format
msgid "Login"
msgstr "כניסה"

#: loginjob.cpp:168
#, kde-format
msgid ""
"Could not authenticate to the SMTP server because no matching authentication "
"method has been found"
msgstr "לא ניתן לאמת את שרת ה־SMTP כיוון שלא נמצאה שיטת אימות תואמת"

#: loginjob.cpp:227
#, kde-format
msgid "Token expired"
msgstr "האסימון פג"

#: loginjob.cpp:271
#, kde-format
msgid "Login failed, cannot initialize the SASL library"
msgstr "הכניסה נכשלה, לא ניתן להפעיל את ספריית ה־SASL"

#: sendjob.cpp:58
#, kde-format
msgid "SendJob"
msgstr "שליחת משימה"

#: sendjob.cpp:107
#, kde-format
msgid ""
"Could not send the message because either the sender or recipient field is "
"missing or invalid"
msgstr "לא ניתן לשלוח את ההודעה כיוון ששדה המוען או הנמען חסרים או שגויים"

#: sendjob.cpp:115
#, kde-format
msgid ""
"Could not send the message because it exceeds the maximum allowed size of %1 "
"bytes. (Message size: %2 bytes.)"
msgstr ""
"לא ניתן לשלוח את ההודעה כיוון שהיא חורגת מהגודל המרבי המותר על סך %1 בתים. "
"(גודל ההודעה: %2 בתים.)"

#: sendjob.cpp:124
#, kde-format
msgid "The message needs and server does not support UTF-8 email addresses"
msgstr "ההודעה צריכה והשרת לא מספק תמיכה בכתובות דוא״ל ב־UTF-8"
