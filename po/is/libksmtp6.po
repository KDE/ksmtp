#: job.cpp:60
#, kde-format
msgid "Service not available"
msgstr "Þjónustan er ekki tiltæk"

#: job.cpp:62
#, kde-format
msgid "Mailbox unavailable. The server said: %1"
msgstr "Pósthólf ekki tiltækt. Þjónninn svaraði: \"%1"

#: job.cpp:64
#, kde-format
msgid "Insufficient storage space on server. The server said: %1"
msgstr "Ekki nóg geymslupláss á þjóninum. Þjónninn svaraði: \"%1"

#: job.cpp:66
#, kde-format
msgid "Server error: %1"
msgstr "Villa á þjóni: %1"

#: job.cpp:75
#, kde-format
msgid "Connection to server lost."
msgstr "Tenging við netþjón hefur rofnað."

#: loginjob.cpp:77
#, kde-format
msgid "Login"
msgstr "Innskráning"

#: loginjob.cpp:168
#, kde-format
msgid ""
"Could not authenticate to the SMTP server because no matching authentication "
"method has been found"
msgstr ""
"Gat ekki auðkennt inn á SMTP-þjóninn þar sem engin samsvarandi "
"auðkenningaraðferð fannst"

#: loginjob.cpp:227
#, kde-format
msgid "Token expired"
msgstr "Auðkenningarteiknið er útrunnið"

#: loginjob.cpp:271
#, kde-format
msgid "Login failed, cannot initialize the SASL library"
msgstr "Innskráning mistókst, tekst ekki að frumstilla SASL-aðgerðasafn"

#: sendjob.cpp:53
#, kde-format
msgid "SendJob"
msgstr "SendJob"

#: sendjob.cpp:102
#, kde-format
msgid ""
"Could not send the message because either the sender or recipient field is "
"missing or invalid"
msgstr ""
"Tókst ekki að senda skilaboðin því annað hvort vantar reit með sendanda eða "
"viðtakanda eða hann er ógildur"

#: sendjob.cpp:110
#, kde-format
msgid ""
"Could not send the message because it exceeds the maximum allowed size of %1 "
"bytes. (Message size: %2 bytes.)"
msgstr ""
"Tókst ekki að senda skilaboðin því þau fara yfir leyfðu hámarksstærðina %1 "
"bæti. (Stærð skilaboða: %2 bæti.)"
